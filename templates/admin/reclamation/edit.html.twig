<script>
    // Solution: Créer un bouton de test pour activer l'audio
    // Le navigateur exige une interaction utilisateur AVANT de pouvoir jouer un son
    
    let audioContext = null;
    let audioAllowed = false;
    
    // Fonction pour initialiser l'audio (doit être appelée après un clic utilisateur)
    function initAudio() {
        if (!audioContext) {
            try {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                audioAllowed = true;
                console.log('Audio prêt !');
            } catch(e) {
                console.log('Audio non supporté');
            }
        }
        return audioContext;
    }
    
    // Son d'avion
    function playPlaneSound() {
        if (!audioAllowed || !audioContext) {
            console.log('Audio non autorisé');
            return;
        }
        
        try {
            const now = audioContext.currentTime;
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.type = 'sine';
            oscillator.frequency.value = 100;
            gainNode.gain.value = 0.2;
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            oscillator.start();
            oscillator.frequency.exponentialRampToValueAtTime(800, now + 0.4);
            gainNode.gain.exponentialRampToValueAtTime(0.00001, now + 0.5);
            oscillator.stop(now + 0.5);
            
            // Réactiver le contexte si suspendu
            if (audioContext.state === 'suspended') {
                audioContext.resume();
            }
        } catch(e) {
            console.log('Erreur:', e);
        }
    }
    
    // Activer l'audio au premier clic n'importe où sur la page
    function enableAudioOnFirstClick() {
        const enableAudio = function() {
            initAudio();
            // Jouer un petit son silencieux pour activer
            if (audioContext) {
                const silent = audioContext.createOscillator();
                const gain = audioContext.createGain();
                gain.gain.value = 0.00001;
                silent.connect(gain);
                gain.connect(audioContext.destination);
                silent.start();
                silent.stop(0.001);
                audioContext.resume();
            }
            document.removeEventListener('click', enableAudio);
            document.removeEventListener('keydown', enableAudio);
        };
        
        document.addEventListener('click', enableAudio);
        document.addEventListener('keydown', enableAudio);
    }
    
    enableAudioOnFirstClick();
    
    // Gestion du formulaire
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('.reply-container form');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                const textarea = form.querySelector('textarea[name="reponse"]');
                var replyErr = document.getElementById('replyError');
                if (replyErr) { replyErr.style.display = 'none'; replyErr.textContent = ''; }

                if (!textarea.value.trim()) {
                    e.preventDefault();
                    if (replyErr) {
                        replyErr.textContent = 'La réponse est obligatoire.';
                        replyErr.style.display = 'block';
                    }
                    textarea.style.outline = '2px solid #c62828';
                    textarea.focus();
                    return false;
                }
                textarea.style.outline = '';
                
                // Initialiser l'audio si ce n'est pas déjà fait
                initAudio();
                
                // Jouer le son
                playPlaneSound();
                
                // Créer l'overlay
                const loader = document.createElement('div');
                loader.className = 'fullscreen-loader';
                loader.innerHTML = `
                    <div class="loader-container">
                        <div class="arrow">✈️</div>
                        <div class="loader-text">Envoi en cours...</div>
                    </div>
                `;
                document.body.appendChild(loader);
                
                return true;
            });
        }
    });
</script>

