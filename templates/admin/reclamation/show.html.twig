{# templates/admin/reclamation/show.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Détails Réclamation - Admin UniBank+{% endblock %}

{% block body %}
<style>
    /* ============================================
       DESIGN DYNAMIQUE - ANIMATIONS & COULEURS
       Style moderne sans modification HTML
    ============================================ */
    
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
    
    :root {
        --primary: #4f46e5;
        --primary-dark: #4338ca;
        --primary-light: #818cf8;
        --secondary: #06b6d4;
        --success: #10b981;
        --danger: #ef4444;
        --warning: #f59e0b;
        --info: #3b82f6;
        --purple: #8b5cf6;
        --pink: #ec4899;
        --orange: #f97316;
    }
    
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        background-attachment: fixed;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        min-height: 100vh;
        padding: 2rem;
        position: relative;
    }
    
    /* Effet de particules flottantes */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%);
        pointer-events: none;
        animation: floatBg 10s infinite alternate;
    }
    
    @keyframes floatBg {
        0% { opacity: 0.3; transform: scale(1); }
        100% { opacity: 0.6; transform: scale(1.1); }
    }
    
    /* Container principal */
    .details-container {
        max-width: 900px;
        margin: 0 auto;
        animation: fadeIn 0.8s ease-out;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    /* Titre principal - TEXTE BLEU sur fond semi-transparent */
    h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #1e3a8a;
        margin-bottom: 2rem;
        text-align: center;
        letter-spacing: -0.01em;
        position: relative;
        padding: 1rem 2rem;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border-radius: 1rem;
        display: inline-block;
        width: auto;
        left: 50%;
        transform: translateX(-50%);
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        border: 1px solid rgba(255,255,255,0.5);
        animation: titleGlow 2s ease-in-out infinite;
    }
    
    @keyframes titleGlow {
        0%, 100% { 
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
            background: rgba(255, 255, 255, 0.85);
        }
        50% { 
            box-shadow: 0 10px 35px -5px rgba(30, 58, 138, 0.2);
            background: rgba(255, 255, 255, 0.95);
        }
    }
    
    /* Style des paragraphes */
    p {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 1rem;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        animation: slideInRight 0.5s ease-out backwards;
        border-left: 4px solid transparent;
    }
    
    /* Animation d'entrée différente pour chaque élément */
    p:nth-child(2) { animation-delay: 0.1s; animation-name: slideInLeft; }
    p:nth-child(3) { animation-delay: 0.2s; animation-name: slideInRight; }
    p:nth-child(4) { animation-delay: 0.3s; animation-name: slideInLeft; }
    p:nth-child(5) { animation-delay: 0.4s; animation-name: slideInRight; }
    p:nth-child(6) { animation-delay: 0.5s; animation-name: slideInLeft; }
    p:nth-child(7) { animation-delay: 0.6s; animation-name: slideInRight; }
    
    @keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    @keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    /* Effet de survol */
    p:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.15), 0 10px 10px -5px rgba(0,0,0,0.02);
    }
    
    /* Ligne de couleur à gauche animée */
    p::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        transform: scaleY(0);
        transition: transform 0.3s ease;
        transform-origin: top;
    }
    
    p:hover::before {
        transform: scaleY(1);
    }
    
    /* Style des strong */
    p strong {
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: linear-gradient(135deg, #4f46e5, #06b6d4);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        display: inline-block;
        min-width: 100px;
    }
    
    /* Valeur après strong */
    p strong + * {
        font-weight: 500;
        color: #1f2937;
        margin-left: 0.5rem;
    }
    
    /* Style spécial pour l'ID */
    p:first-of-type {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-left-color: #fff;
    }
    
    p:first-of-type strong,
    p:first-of-type strong + * {
        background: white;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 800;
    }
    
    p:first-of-type strong + * {
        font-family: 'Courier New', monospace;
        font-size: 1.2rem;
        background: white;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    
    /* Badge statut animé */
    p:nth-of-type(5) {
        animation: borderPulse 2s infinite;
    }
    
    @keyframes borderPulse {
        0%, 100% { border-left-color: transparent; }
        50% { border-left-color: var(--primary); }
    }
    
    p:nth-of-type(5) strong + * {
        display: inline-flex;
        align-items: center;
        padding: 0.375rem 1rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        animation: statusGlow 2s infinite;
    }
    
    @keyframes statusGlow {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }
    
    /* Statut - En attente */
    p:nth-of-type(5):has(strong + *:contains("en_attente")) strong + *,
    p:nth-of-type(5):has(strong + *:contains("en attente")) strong + * {
        background: linear-gradient(135deg, #fef3c7, #fde68a);
        color: #d97706;
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
    }
    
    /* Statut - En cours */
    p:nth-of-type(5):has(strong + *:contains("en_cours")) strong + *,
    p:nth-of-type(5):has(strong + *:contains("en cours")) strong + * {
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        color: #2563eb;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
    }
    
    /* Statut - Traité */
    p:nth-of-type(5):has(strong + *:contains("traite")) strong + *,
    p:nth-of-type(5):has(strong + *:contains("traité")) strong + * {
        background: linear-gradient(135deg, #d1fae5, #a7f3d0);
        color: #059669;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
    }
    
    /* Statut - Rejeté */
    p:nth-of-type(5):has(strong + *:contains("rejete")) strong + *,
    p:nth-of-type(5):has(strong + *:contains("rejeté")) strong + * {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #dc2626;
        box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
    }
    
    /* Style spécial pour la description */
    p:nth-of-type(4) {
        background: linear-gradient(135deg, #fffbeb, #fef3c7);
    }
    
    p:nth-of-type(4) strong + * {
        font-style: italic;
        line-height: 1.6;
        display: block;
        margin-top: 0.5rem;
        margin-left: 0;
        padding: 0.5rem;
        background: rgba(255,255,255,0.5);
        border-radius: 0.5rem;
    }
    
    /* Style pour la date */
    p:last-of-type {
        background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
    }
    
    p:last-of-type strong + * {
        font-family: monospace;
        font-size: 0.95rem;
    }
    
    /* Icônes animées avant chaque paragraphe */
    p {
        position: relative;
        padding-left: 3rem;
    }
    
    p::after {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.25rem;
        animation: iconBounce 2s infinite;
    }
    
    @keyframes iconBounce {
        0%, 100% { transform: translateY(-50%) scale(1); }
        50% { transform: translateY(-60%) scale(1.1); }
    }
    
    p:first-of-type::after { content: "🆔"; }
    p:nth-of-type(2)::after { content: "👤"; animation-delay: 0.2s; }
    p:nth-of-type(3)::after { content: "📌"; animation-delay: 0.4s; }
    p:nth-of-type(4)::after { content: "📝"; animation-delay: 0.6s; }
    p:nth-of-type(5)::after { content: "⚡"; animation-delay: 0.8s; }
    p:nth-of-type(6)::after { content: "📅"; animation-delay: 1s; }
    
    /* Responsive */
    @media (max-width: 768px) {
        body {
            padding: 1rem;
        }
        
        h1 {
            font-size: 1.25rem;
            padding: 0.75rem 1.5rem;
            white-space: nowrap;
        }
        
        p {
            padding: 1rem;
            padding-left: 2.5rem;
        }
        
        p::after {
            left: 0.75rem;
            font-size: 1rem;
        }
        
        p strong {
            display: block;
            margin-bottom: 0.5rem;
        }
        
        p strong + * {
            margin-left: 0;
            display: inline-block;
        }
    }
    
    /* Style pour l'impression */
    @media print {
        body {
            background: white;
            padding: 0;
        }
        
        body::before {
            display: none;
        }
        
        h1 {
            background: none;
            color: #1e3a8a;
            box-shadow: none;
            border: 1px solid #ddd;
        }
        
        p {
            break-inside: avoid;
            box-shadow: none;
            border: 1px solid #ddd;
            background: white;
        }
        
        p:hover {
            transform: none;
        }
    }
</style>

<div class="details-container">
    <h1>📋 Détails de la réclamation</h1>
    
    <!-- VOTRE CODE HTML EXISTANT (COMPLÈTEMENT INCHANGÉ) -->
    <p><strong>ID :</strong> {{ reclamation.id }}</p>
    <p><strong>Client :</strong> {{ reclamation.utilisateur.prenom }} {{ reclamation.utilisateur.nom }}</p>
    <p><strong>Sujet :</strong> {{ reclamation.sujet }}</p>
    <p><strong>Description :</strong> {{ reclamation.description }}</p>
    <p><strong>Statut :</strong> {{ reclamation.statut }}</p>
    <p><strong>Date :</strong> {{ reclamation.dateReclamation|date('d/m/Y H:i') }}</p>
</div>

{% endblock %}