<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Liste des réclamations - UniBank+</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            font-size: 12px;
        }
        h1 {
            color: #1a2c3e;
            border-bottom: 3px solid #f4a261;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        .header h1 {
            margin-bottom: 5px;
        }
        .header p {
            color: #666;
            font-size: 11px;
            margin: 0;
        }
        .stats {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }
        .stat-box {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 8px;
            flex: 1;
            text-align: center;
            min-width: 100px;
        }
        .stat-label {
            font-size: 11px;
            color: #666;
            margin-bottom: 5px;
        }
        .stat-value {
            font-size: 20px;
            font-weight: bold;
            color: #f4a261;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }
        th {
            background-color: #f4a261;
            color: white;
            font-weight: bold;
            font-size: 11px;
        }
        td {
            font-size: 10px;
        }
        .badge {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 9px;
            font-weight: bold;
        }
        .badge.en_attente { background: #FFF3E0; color: #FF9800; }
        .badge.en_cours { background: #E3F2FD; color: #2196F3; }
        .badge.traite { background: #E8F5E9; color: #4CAF50; }
        .badge.rejete { background: #FFEBEE; color: #F44336; }
        
        .sentiment {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 9px;
            font-weight: bold;
        }
        .sentiment.positif { background: #E8F5E9; color: #4CAF50; }
        .sentiment.negatif { background: #FFEBEE; color: #F44336; }
        .sentiment.neutre { background: #F5F5F5; color: #757575; }
        
        .footer {
            margin-top: 30px;
            text-align: center;
            font-size: 9px;
            color: #999;
            border-top: 1px solid #eee;
            padding-top: 15px;
        }
        .filters-info {
            background: #f9f9f9;
            padding: 10px;
            margin-bottom: 20px;
            border-left: 3px solid #f4a261;
            font-size: 10px;
            border-radius: 4px;
        }
        .filters-info strong {
            color: #333;
        }
        .client-info {
            line-height: 1.4;
        }
        .client-name {
            font-weight: bold;
            color: #1a2c3e;
        }
        .client-email {
            font-size: 9px;
            color: #666;
        }
        .sujet {
            font-weight: bold;
            margin-bottom: 3px;
        }
        .description {
            font-size: 9px;
            color: #666;
        }
        .response-text {
            font-size: 9px;
            color: #4CAF50;
        }
        .no-response {
            color: #FF9800;
            font-style: italic;
        }
        .page-break {
            page-break-before: always;
        }
        .text-center {
            text-align: center;
        }
        .mb-10 {
            margin-bottom: 10px;
        }
        .mt-20 {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1> UniBank+ - Liste des réclamations</h1>
        <p>Généré le {{ generated_at|date('d/m/Y à H:i:s') }}</p>
    </div>
    
    <div class="stats">
        <div class="stat-box">
            <div class="stat-label">Total</div>
            <div class="stat-value">{{ stats.total }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">En attente</div>
            <div class="stat-value">{{ stats.en_attente }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">En cours</div>
            <div class="stat-value">{{ stats.en_cours }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Traitée</div>
            <div class="stat-value">{{ stats.traite }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Rejetée</div>
            <div class="stat-value">{{ stats.rejete }}</div>
        </div>
    </div>
    
    {% if filters.status or filters.type or filters.sentiment or filters.search %}
    <div class="filters-info">
        <strong>📊 Filtres appliqués :</strong><br>
        {% if filters.status and filters.status != 'all' %} 
            • Statut: <strong>{{ filters.status|replace({'_': ' '})|capitalize }}</strong><br>
        {% endif %}
        {% if filters.type and filters.type != 'all' %} 
            • Type: <strong>{{ filters.type|capitalize }}</strong><br>
        {% endif %}
        {% if filters.sentiment and filters.sentiment != 'all' %} 
            • Sentiment: <strong>{{ filters.sentiment|capitalize }}</strong><br>
        {% endif %}
        {% if filters.search %} 
            • Recherche: <strong>"{{ filters.search }}"</strong><br>
        {% endif %}
    </div>
    {% endif %}
    
    <table>
        <thead>
            <tr>
                <th style="width: 15%">Client</th>
                <th style="width: 10%">Type</th>
                <th style="width: 25%">Sujet / Description</th>
                <th style="width: 8%">Sentiment</th>
                <th style="width: 10%">Statut</th>
                <th style="width: 10%">Date</th>
                <th style="width: 22%">Réponse</th>
            </tr>
        </thead>
        <tbody>
            {% for r in reclamations %}
            <tr>
                <td>
                    <div class="client-info">
                        <div class="client-name">{{ r.utilisateur.prenom }} {{ r.utilisateur.nom }}</div>
                        <div class="client-email">{{ r.utilisateur.email }}</div>
                    </div>
                </td>
                <td>
                    {% if r.type == 'technique' %}
                        🔧 Technique
                    {% elseif r.type == 'compte' %}
                        👤 Compte
                    {% elseif r.type == 'transaction' %}
                        💰 Transaction
                    {% elseif r.type == 'carte' %}
                        💳 Carte
                    {% elseif r.type == 'credit' %}
                        📊 Crédit
                    {% else %}
                        💬 Autre
                    {% endif %}
                </td>
                <td>
                    <div class="sujet">{{ r.sujet }}</div>
                    <div class="description">{{ r.description|slice(0, 150) }}{% if r.description|length > 150 %}...{% endif %}</div>
                </td>
                <td class="text-center">
                    {% if r.sentiment %}
                        <span class="sentiment {{ r.sentiment }}">
                            {% if r.sentiment == 'positif' %}
                                😊 Positif
                            {% elseif r.sentiment == 'negatif' %}
                                😞 Négatif
                            {% else %}
                                😐 Neutre
                            {% endif %}
                        </span>
                    {% else %}
                        <span class="sentiment neutre">❓ Non analysé</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    <span class="badge {{ r.statut }}">
                        {% if r.statut == 'en_attente' %}
                            ⏳ En attente
                        {% elseif r.statut == 'en_cours' %}
                            🔄 En cours
                        {% elseif r.statut == 'traite' %}
                            ✅ Traité
                        {% else %}
                            ❌ Rejeté
                        {% endif %}
                    </span>
                </td>
                <td class="text-center">
                    {{ r.dateReclamation|date('d/m/Y') }}<br>
                    <small>{{ r.dateReclamation|date('H:i') }}</small>
                </td>
                <td>
                    {% if r.reponse %}
                        <div class="response-text">
                            📝 {{ r.reponse|slice(0, 150) }}{% if r.reponse|length > 150 %}...{% endif %}
                        </div>
                        {% if r.reponseDate %}
                            <div style="font-size: 8px; color: #999; margin-top: 5px;">
                                📅 {{ r.reponseDate|date('d/m/Y H:i') }}
                            </div>
                        {% endif %}
                    {% else %}
                        <span class="no-response">⏰ En attente de réponse</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    
    {% if reclamations|length == 0 %}
    <div class="text-center mt-20" style="padding: 40px; background: #f9f9f9; border-radius: 8px;">
        <p style="color: #999;">📭 Aucune réclamation trouvée avec les filtres sélectionnés.</p>
    </div>
    {% endif %}
    
    <div class="footer">
        <p>UniBank+ - Tous droits réservés</p>
        <p>Ce document est généré automatiquement le {{ generated_at|date('d/m/Y à H:i:s') }} - {{ reclamations|length }} réclamation(s) affichée(s)</p>
    </div>
</body>
</html>