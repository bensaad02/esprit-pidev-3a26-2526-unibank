{% block javascripts %}
  {{ parent() }}
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof L === 'undefined') {
        return;
      }

      var modalEl = document.getElementById('branchMapModal');
      var mapEl = document.getElementById('unibank-leaflet-map');
      var listEl = document.getElementById('branch-mini-list');

      if (!modalEl || !mapEl || !listEl) {
        return;
      }

      var branches = [
        {
          name: 'UniBank+ Tunis Centre',
          city: 'Tunis',
          coords: [36.8008, 10.1809],
          address: 'Avenue Habib Bourguiba',
          hours: 'Lun - Ven : 08:00 - 17:00'
        },
        {
          name: 'UniBank+ Lac 2',
          city: 'Les Berges du Lac',
          coords: [36.8421, 10.2726],
          address: 'Zone affaires, Lac 2',
          hours: 'Lun - Ven : 08:30 - 18:00'
        },
        {
          name: 'UniBank+ Sousse',
          city: 'Sousse',
          coords: [35.8256, 10.6411],
          address: 'Boulevard principal',
          hours: 'Lun - Sam : 08:00 - 16:00'
        },
        {
          name: 'UniBank+ Sfax',
          city: 'Sfax',
          coords: [34.7406, 10.7603],
          address: 'Agence regionale Sfax',
          hours: 'Lun - Ven : 08:00 - 17:30'
        }
      ];

      var map = null;
      var markers = [];
      var activeCard = null;

      function setActiveCard(index) {
        if (activeCard) {
          activeCard.classList.remove('is-active');
        }
        activeCard = listEl.querySelector('[data-branch-index="' + index + '"]');
        if (activeCard) {
          activeCard.classList.add('is-active');
        }
      }

      function focusBranch(index) {
        if (!map || !markers[index]) {
          return;
        }
        map.flyTo(branches[index].coords, 11, { duration: 1.1 });
        markers[index].openPopup();
        setActiveCard(index);
      }

      function initMap() {
        if (map) {
          map.invalidateSize();
          return;
        }

        map = L.map(mapEl, { scrollWheelZoom: false }).setView([35.8, 10.4], 7);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var branchIcon = L.divIcon({
          className: 'unibank-branch-marker',
          html: '<div style="width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,#2259d6,#4d87ff);border:4px solid rgba(255,255,255,0.98);box-shadow:0 8px 20px rgba(34,89,214,.34);"></div>',
          iconSize: [18, 18],
          iconAnchor: [9, 9]
        });

        branches.forEach(function (branch, index) {
          var marker = L.marker(branch.coords, { icon: branchIcon }).addTo(map);
          marker.bindPopup(
            '<div class="unibank-popup">' +
              '<h6>' + branch.name + '</h6>' +
              '<p><strong>' + branch.city + '</strong><br>' + branch.address + '<br>' + branch.hours + '</p>' +
            '</div>'
          );
          marker.on('click', function () {
            setActiveCard(index);
          });
          markers.push(marker);

          var card = document.createElement('button');
          card.type = 'button';
          card.className = 'branch-mini-card';
          card.setAttribute('data-branch-index', index);
          card.innerHTML =
            '<strong>' + branch.name + '</strong>' +
            '<span>' + branch.address + '</span>' +
            '<span>' + branch.hours + '</span>';
          card.addEventListener('click', function () {
            focusBranch(index);
          });
          listEl.appendChild(card);
        });

        focusBranch(0);
      }

      $('#branchMapModal').on('shown.bs.modal', function () {
        initMap();
        setTimeout(function () {
          if (map) {
            map.invalidateSize();
          }
        }, 120);
      });
    });
  </script>
{% endblock %}
