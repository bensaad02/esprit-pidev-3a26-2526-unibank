{% extends 'base.html.twig' %}

{% block title %}UniBank+ - Votre banque de confiance{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <style>
    .branch-map-modal .modal-content {
      border: none;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 30px 70px rgba(15, 23, 42, 0.24);
    }

    .branch-map-head {
      background: linear-gradient(135deg, #17398a, #2259d6 58%, #4f86ff);
      color: #fff;
      padding: 18px 22px;
    }

    .branch-map-head h4 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 800;
    }

    .branch-map-head p {
      margin: 6px 0 0;
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.92rem;
    }

    .branch-map-body {
      padding: 18px;
      background: linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
    }

    #unibank-leaflet-map {
      height: 330px;
      width: 100%;
      border-radius: 18px;
      border: 1px solid #d7e3fb;
      overflow: hidden;
      margin-bottom: 14px;
    }

    .branch-mini-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .branch-mini-card {
      background: #fff;
      border: 1px solid #dde7fb;
      border-radius: 16px;
      padding: 12px 14px;
      cursor: pointer;
      transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

    .branch-mini-card:hover,
    .branch-mini-card.is-active {
      transform: translateY(-1px);
      border-color: #98b8ff;
      box-shadow: 0 10px 24px rgba(34, 89, 214, 0.12);
    }

    .branch-mini-card strong {
      display: block;
      color: #16306b;
      font-size: 0.95rem;
      margin-bottom: 4px;
    }

    .branch-mini-card span {
      display: block;
      color: #61718f;
      font-size: 0.84rem;
      line-height: 1.5;
    }

    .leaflet-popup-content-wrapper {
      border-radius: 14px;
    }

    .unibank-popup h6 {
      margin: 0 0 5px;
      font-size: 0.98rem;
      font-weight: 800;
      color: #16306b;
    }

    .unibank-popup p {
      margin: 0;
      color: #5f6f8e;
      font-size: 0.84rem;
      line-height: 1.45;
    }

    @media (max-width: 767.98px) {
      .branch-mini-list {
        grid-template-columns: 1fr;
      }

      #unibank-leaflet-map {
        height: 280px;
      }
    }
  </style>
{% endblock %}

