{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - UniBank+{% endblock %}

{% block body %}
<div class="site-section bg-light" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="bg-white p-5 rounded shadow">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <div style="width:64px;height:64px;background:linear-gradient(135deg,#dcfce7,#bbf7d0);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                                <i class="fas fa-key" style="font-size:24px;color:#16a34a;"></i>
                            </div>
                        </div>
                        <h2 class="h4 text-black">Nouveau mot de passe</h2>
                        <p class="text-muted" style="font-size:13px;">Choisissez un mot de passe fort pour securiser votre compte.</p>
                    </div>

                    <form method="post" id="newPwdForm">
                        <div class="form-group">
                            <label class="text-black font-weight-bold" style="font-size:14px;">Nouveau mot de passe</label>
                            <input type="password" name="password" id="password" required
                                   class="form-control {{ errors.password is defined ? 'is-invalid' : '' }}"
                                   placeholder="Nouveau mot de passe">
                            {% if errors.password is defined %}
                                <div class="invalid-feedback d-block">{{ errors.password }}</div>
                            {% endif %}
                            <div id="pwd-strength" class="mt-2" style="display:none;">
                                <div style="height:4px;border-radius:4px;background:#e2e8f0;overflow:hidden;">
                                    <div id="strength-bar" style="height:100%;width:0;transition:width 0.3s,background 0.3s;border-radius:4px;"></div>
                                </div>
                                <small id="strength-label" class="text-muted"></small>
                            </div>
                            <small class="text-muted" style="font-size:12px;">Min. 8 caracteres, 1 majuscule, 1 minuscule, 1 chiffre.</small>
                        </div>

                        <div class="form-group">
                            <label class="text-black font-weight-bold" style="font-size:14px;">Confirmer le mot de passe</label>
                            <input type="password" name="confirm" id="confirm" required
                                   class="form-control {{ errors.confirm is defined ? 'is-invalid' : '' }}"
                                   placeholder="Confirmer le mot de passe">
                            {% if errors.confirm is defined %}
                                <div class="invalid-feedback d-block">{{ errors.confirm }}</div>
                            {% endif %}
                            <div id="match-msg" style="font-size:12px;margin-top:4px;display:none;"></div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block py-2 mt-2" style="border-radius:10px;font-weight:600;">
                            <i class="fas fa-save mr-1"></i> Enregistrer le mot de passe
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
    document.getElementById('password').addEventListener('input', function() {
        var v = this.value;
        var bar = document.getElementById('strength-bar');
        var label = document.getElementById('strength-label');
        var wrap = document.getElementById('pwd-strength');
        if (!v) { wrap.style.display = 'none'; return; }
        wrap.style.display = 'block';
        var score = 0;
        if (v.length >= 8) score++;
        if (/[a-z]/.test(v)) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/\d/.test(v)) score++;
        if (/[^a-zA-Z0-9]/.test(v)) score++;
        var pct = (score / 5) * 100;
        var color = score <= 2 ? '#ef4444' : score === 3 ? '#f59e0b' : '#22c55e';
        var txt = score <= 2 ? 'Faible' : score === 3 ? 'Moyen' : 'Fort';
        bar.style.width = pct + '%';
        bar.style.background = color;
        label.textContent = txt;
        label.style.color = color;
        checkMatch();
    });

    document.getElementById('confirm').addEventListener('input', checkMatch);

    function checkMatch() {
        var p = document.getElementById('password').value;
        var c = document.getElementById('confirm').value;
        var msg = document.getElementById('match-msg');
        if (!c) { msg.style.display = 'none'; return; }
        msg.style.display = 'block';
        if (p === c) {
            msg.textContent = '✓ Les mots de passe correspondent.';
            msg.style.color = '#22c55e';
        } else {
            msg.textContent = '✗ Les mots de passe ne correspondent pas.';
            msg.style.color = '#ef4444';
        }
    }
    </script>
{% endblock %}
{% endblock %}
