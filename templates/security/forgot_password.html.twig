{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublie - UniBank+{% endblock %}

{% block body %}
<div class="site-section bg-light" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="bg-white p-5 rounded shadow">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <div style="width:64px;height:64px;background:linear-gradient(135deg,#dbeafe,#bfdbfe);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                                <i class="fas fa-lock" style="font-size:24px;color:#2259d6;"></i>
                            </div>
                        </div>
                        <h2 class="h4 text-black">Mot de passe oublie ?</h2>
                        <p class="text-muted" style="font-size:14px;">Entrez votre email et nous vous enverrons un code de reinitialisation.</p>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger" style="font-size:13px;padding:10px 14px;border-radius:8px;">
                            <i class="fas fa-exclamation-circle mr-1"></i> {{ error }}
                        </div>
                    {% endif %}

                    <form method="post" id="forgotForm" novalidate>
                        <div class="form-group">
                            <label class="text-black font-weight-bold" style="font-size:14px;">Adresse email</label>
                            <input type="email" name="email" id="forgotEmail" value="{{ email }}" required autofocus
                                   class="form-control" placeholder="votre@email.com"
                                   style="border-radius:10px;padding:12px 16px;border:1.5px solid #e2e8f0;">
                            <div id="forgotEmailError" style="display:none;color:#dc2626;font-size:12px;font-weight:600;margin-top:5px;"></div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block py-2 mt-3" style="border-radius:10px;font-weight:600;">
                            Envoyer le code
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a href="{{ path('app_login') }}" style="font-size:14px;color:#2259d6;">
                            <i class="fas fa-arrow-left mr-1"></i> Retour a la connexion
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
    document.getElementById('forgotForm').addEventListener('submit', function(e) {
        var email = document.getElementById('forgotEmail');
        var err = document.getElementById('forgotEmailError');
        err.style.display = 'none'; err.textContent = '';
        email.style.borderColor = '#e2e8f0';
        var valid = true;

        if (!email.value.trim()) {
            err.textContent = "L'adresse email est obligatoire.";
            err.style.display = 'block';
            email.style.borderColor = '#dc2626';
            valid = false;
        } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
            err.textContent = "Veuillez saisir une adresse email valide.";
            err.style.display = 'block';
            email.style.borderColor = '#dc2626';
            valid = false;
        }

        if (!valid) e.preventDefault();
    });
    document.getElementById('forgotEmail').addEventListener('input', function() {
        document.getElementById('forgotEmailError').style.display = 'none';
        this.style.borderColor = '#e2e8f0';
    });
    </script>
{% endblock %}
{% endblock %}
