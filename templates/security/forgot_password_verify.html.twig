{% extends 'base.html.twig' %}

{% block title %}Verification du code - UniBank+{% endblock %}

{% block body %}
<div class="site-section bg-light" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="bg-white p-5 rounded shadow">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <div style="width:64px;height:64px;background:linear-gradient(135deg,#dbeafe,#bfdbfe);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                                <i class="fas fa-envelope-open-text" style="font-size:24px;color:#2259d6;"></i>
                            </div>
                        </div>
                        <h2 class="h4 text-black">Verifiez votre email</h2>
                        <p class="text-muted" style="font-size:13px;">
                            Si un compte existe pour <strong>{{ email }}</strong>, un code a 6 chiffres vient d'etre envoye. Il expire dans <strong>1 heure</strong>.
                        </p>
                    </div>

                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }}" style="font-size:13px;padding:10px 14px;border-radius:8px;">
                                <i class="fas fa-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }} mr-1"></i> {{ message }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {% if error %}
                        <div class="alert alert-danger" style="font-size:13px;padding:10px 14px;border-radius:8px;">
                            <i class="fas fa-exclamation-circle mr-1"></i> {{ error }}
                        </div>
                    {% endif %}

                    <form method="post" id="verifyCodeForm" novalidate>
                        <input type="hidden" name="email" value="{{ email }}">
                        <div class="form-group">
                            <label class="text-black font-weight-bold" style="font-size:14px;">Code de verification</label>
                            <input type="text" name="code" id="verifyCode" required autofocus
                                   class="form-control text-center font-weight-bold"
                                   placeholder="XXXXXX"
                                   maxlength="6"
                                   style="border-radius:10px;padding:14px 16px;font-size:24px;letter-spacing:10px;border:1.5px solid #e2e8f0;text-transform:uppercase;">
                            <div id="verifyCodeError" style="display:none;color:#dc2626;font-size:12px;font-weight:600;margin-top:5px;"></div>
                            <small class="text-muted">Entrez le code a 6 caracteres recu par email.</small>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block py-2 mt-3" style="border-radius:10px;font-weight:600;">
                            Verifier le code
                        </button>
                    </form>

                    <div class="text-center mt-3" style="font-size:13px;">
                        <span class="text-muted">Vous n'avez pas recu le code ?</span>
                        <a href="{{ path('app_forgot_password_resend', {email: email}) }}" class="ml-1" style="color:#2259d6;font-weight:600;">Renvoyer</a>
                    </div>
                    <div class="text-center mt-3">
                        <a href="{{ path('app_forgot_password') }}" style="font-size:13px;color:#2259d6;">
                            <i class="fas fa-arrow-left mr-1"></i> Changer d'email
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
    document.getElementById('verifyCodeForm').addEventListener('submit', function(e) {
        var code = document.getElementById('verifyCode');
        var err = document.getElementById('verifyCodeError');
        err.style.display = 'none'; err.textContent = '';
        code.style.borderColor = '#e2e8f0';

        if (!code.value.trim()) {
            err.textContent = 'Le code de vérification est obligatoire.';
            err.style.display = 'block';
            code.style.borderColor = '#dc2626';
            e.preventDefault();
        }
    });
    document.getElementById('verifyCode').addEventListener('input', function() {
        this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        document.getElementById('verifyCodeError').style.display = 'none';
        this.style.borderColor = '#e2e8f0';
    });
    </script>
{% endblock %}
{% endblock %}
