<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: Arial;
            font-size: 12px;
            color: #333;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #2b6cff;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .logo {
            font-size: 20px;
            font-weight: bold;
            color: #2b6cff;
        }

        .title {
            font-size: 16px;
            margin-top: 5px;
        }

        .date {
            font-size: 10px;
            color: #777;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th {
            background: #2b6cff;
            color: white;
            padding: 8px;
        }

        td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: center;
        }

        .badge {
            padding: 4px 6px;
            border-radius: 4px;
            color: white;
            font-size: 10px;
        }

        .active { background: green; }
        .blocked { background: red; }
        .pending { background: orange; }

        .footer {
            margin-top: 30px;
            text-align: center;
            font-size: 10px;
            color: #999;
        }
    </style>
</head>
<body>

<!-- HEADER -->
<div class="header">
    <div class="logo">🏦 UniBank+</div>
    <div class="title">Rapport des Cartes Bancaires</div>
    <div class="date">Date: {{ "now"|date("d/m/Y H:i") }}</div>
</div>

<!-- TABLE -->
<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Client</th>
            <th>Type</th>
            <th>Montant</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>
        {% for carte in cartes %}
            <tr>
                <td>{{ carte.id }}</td>
                <td>{{ carte.nom }} {{ carte.prenom }}</td>
                <td>{{ carte.typeCarte }}</td>
                <td>{{ carte.solde }} DT</td>

                <td>
                    <span class="badge 
                        {% if carte.status == 'ACTIVE' %}active
                        {% elseif carte.status == 'BLOCKED' %}blocked
                        {% else %}pending
                        {% endif %}
                    ">
                        {{ carte.status }}
                    </span>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<!-- FOOTER -->
<div class="footer">
    © {{ "now"|date("Y") }} UniBank+ - Tous droits réservés
</div>
<p><strong>Total Solde:</strong> 
{{ cartes|reduce((carry, c) => carry + c.solde, 0) }} DT
</p>
</body>
</html>