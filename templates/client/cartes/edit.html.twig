{% extends 'client/base.html.twig' %}

{% block page_title %}Modifier Carte{% endblock %}

{% block body %}
<div class="container mt-4">

    <h4>Modifier votre carte 💳</h4>

    <div class="card p-4 shadow-sm">

        {{ form_start(form) }}

        <div class="mb-3">
            <label>Type de carte</label>
            {{ form_widget(form.typeCarte, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            <label>Adresse</label>
            {{ form_widget(form.adresse, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            <label>Montant</label>
            {{ form_widget(form.solde, {'attr': {'class': 'form-control'}}) }}
        </div>

        <button class="btn btn-primary">
            💾 Enregistrer
        </button>

        {{ form_end(form) }}

    </div>

</div>
{% endblock %}