            <div class="stat-value-mini">{{ stats.rejete }}</div>
        </div>
    </div>
</div>

<!-- Liste des réclamations -->
<div class="admin-card">
    <div class="card-header">
        <h5><i class="fas fa-list mr-2" style="color:var(--primary);"></i>Mes réclamations ({{ reclamations|length }})</h5>
    </div>
    <div class="card-body">
      
<form method="get" action="{{ path('app_client_reclamations') }}" class="search-bar">

    <!-- Recherche -->
    <div class="search-input-group">
        <i class="fas fa-search search-icon"></i>
        <input type="text"
               name="search"
               value="{{ app.request.get('search') }}"
               placeholder="Rechercher une réclamation..."
               class="search-input">
    </div>

    <!-- TRI -->
    <select name="sort" class="search-select">
        <option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Plus récentes</option>
        <option value="date_asc" {{ sort == 'date_asc' ? 'selected' : '' }}>Plus anciennes</option>
        <option value="statut" {{ sort == 'statut' ? 'selected' : '' }}>Statut</option>
        <option value="type" {{ sort == 'type' ? 'selected' : '' }}>Type</option>
    </select>

    <!-- Bouton -->
    <button type="submit" class="btn-search">
        Appliquer
    </button>

    {% if app.request.get('search') or sort != 'date_desc' %}
        <a href="{{ path('app_client_reclamations') }}" class="btn-reset">
            Réinitialiser
        </a>
    {% endif %}

</form>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Sujet</th>
                    <th>Statut</th>
                    <th>Date</th>
                    <th>Réponse</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for r in reclamations %}
                <tr>
                    <td>
                        <span class="badge-status" style="background:#F0F0F0;color:#666;">
                            {% if r.type == 'technique' %}<i class="fas fa-code"></i> Technique
                            {% elseif r.type == 'compte' %}<i class="fas fa-user"></i> Compte
                            {% elseif r.type == 'transaction' %}<i class="fas fa-exchange-alt"></i> Transaction
                            {% elseif r.type == 'carte' %}<i class="fas fa-credit-card"></i> Carte
                            {% elseif r.type == 'credit' %}<i class="fas fa-hand-holding-usd"></i> Crédit
                            {% else %}<i class="fas fa-comment"></i> Autre
                            {% endif %}
                        </span>
                    </td>
                    <td>
                        <div style="font-weight:500;">{{ r.sujet }}</div>
                        <div style="font-size: 11px; color: var(--text-secondary); margin-top: 3px;">
                            {{ r.description|slice(0, 60) }}{% if r.description|length > 60 %}...{% endif %}
                        </div>
                        {% if r.sentiment %}
                            <div style="margin-top: 5px;">
                                <span class="sentiment-badge sentiment-{{ r.sentiment }}">
                                    {% if r.sentiment == 'positif' %}
                                        <i class="fas fa-smile"></i> Analyse positive
                                    {% elseif r.sentiment == 'negatif' %}
                                        <i class="fas fa-frown"></i> Analyse négative
                                    {% else %}
                                        <i class="fas fa-meh"></i> Analyse neutre
                                    {% endif %}
                                </span>
                            </div>
                        {% endif %}
                        {% if r.imagePath %}
                            <div style="margin-top: 8px;">
                                <img src="{{ asset('uploads/reclamations/' ~ r.imagePath) }}" class="image-preview" alt="Image jointe" onclick="window.open(this.src)">
                            </div>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge-status {{ r.statut }}">
                            {% if r.statut == 'en_attente' %}
                                <i class="fas fa-clock"></i> En attente
                            {% elseif r.statut == 'en_cours' %}
                                <i class="fas fa-spinner fa-pulse"></i> En cours
                            {% elseif r.statut == 'traite' %}
                                <i class="fas fa-check-circle"></i> Traité
                            {% else %}
                                <i class="fas fa-times-circle"></i> Rejeté
                            {% endif %}
                        </span>
                    </td>
                    <td style="font-size:13px;">
                        {{ r.dateReclamation|date('d/m/Y H:i') }}
                    </td>
                    <td>
   {% if r.reponses|length > 0 %}
    {% set rep = r.reponses|sort((a, b) => a.dateReponse <=> b.dateReponse)|last %}

    <div class="response-preview has-response" title="{{ rep.contenu }}">
        <i class="fas fa-reply-all"></i> 
        {{ rep.contenu|slice(0, 50) }}{% if rep.contenu|length > 50 %}...{% endif %}
    </div>

    <div style="font-size: 11px; color: #4CAF50;">
        <i class="fas fa-calendar-alt"></i> 
        {{ rep.dateReponse|date('d/m/Y H:i') }}
    </div>
{% else %}
    <span class="response-preview no-response">
        <i class="fas fa-hourglass-half"></i> En attente de réponse
    </span>
{% endif %}
</td>
                    <td style="white-space:nowrap;">
                        <button type="button" class="btn-action view" title="Voir détails" onclick="$('#detailModal{{ r.id }}').modal('show')">
                            <i class="fas fa-eye"></i>
                        </button>
                        {% if r.statut == 'en_attente' %}
                            <button type="button" class="btn-action edit" title="Modifier" onclick="openEditModal({{ r.id }}, '{{ r.sujet|e('js') }}', '{{ r.description|e('js') }}', '{{ r.type|e('js') }}')">
                                <i class="fas fa-pen"></i>
                            </button>
                          <form method="post" action="{{ path('app_client_reclamation_delete', {id: r.id}) }}" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
    <button type="submit" class="btn-action delete" title="Supprimer" onclick="return confirm('Supprimer cette réclamation ?')">
        <i class="fas fa-trash"></i>
    </button>
</form>
                        {% endif %}
                    </td>
                </tr>

                <!-- Modal Détails -->
                <div class="modal fade modal-admin" id="detailModal{{ r.id }}" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content" style="border:none;border-radius:16px;overflow:hidden;">
                            <div style="background:linear-gradient(135deg,var(--primary),#4C49ED);padding:20px 25px;">
                                <h5 style="color:#fff;font-weight:700;margin:0;">
                                    <i class="fas fa-comment-alt mr-2"></i>Détail de la réclamation
                                </h5>
                                <small style="color:rgba(255,255,255,0.8);">#{{ r.id }} - {{ r.dateReclamation|date('d/m/Y H:i') }}</small>
                            </div>
                            <div style="padding:25px;">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="text-muted" style="font-size:12px;">Type</label>
                                        <div><strong>{% if r.type == 'technique' %}💻 Problème technique{% elseif r.type == 'compte' %}👤 Problème de compte{% elseif r.type == 'transaction' %}💰 Transaction{% elseif r.type == 'carte' %}💳 Carte bancaire{% elseif r.type == 'credit' %}🏦 Crédit{% else %}📝 Autre{% endif %}</strong></div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="text-muted" style="font-size:12px;">Statut</label>
                                        <div><span class="badge-status {{ r.statut }}">{% if r.statut == 'en_attente' %}⏳ En attente{% elseif r.statut == 'en_cours' %}🔄 En cours{% elseif r.statut == 'traite' %}✅ Traité{% else %}❌ Rejeté{% endif %}</span></div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted" style="font-size:12px;">Sujet</label>
                                    <div><strong>{{ r.sujet }}</strong></div>
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted" style="font-size:12px;">Description</label>
                                    <div class="reclamation-detail">{{ r.description|nl2br }}</div>
                                </div>
                                {% if r.imagePath %}
                                <div class="mb-3">
                                    <label class="text-muted" style="font-size:12px;">Image jointe</label>
                                    <div><img src="{{ asset('uploads/reclamations/' ~ r.imagePath) }}" style="max-width:100%;max-height:300px;border-radius:8px;" onclick="window.open(this.src)"></div>
                                </div>
                                {% endif %}
                                {% if r.sentiment %}
                                <div class="mb-3">
                                    <label class="text-muted" style="font-size:12px;">Analyse automatique</label>
                                    <div><span class="sentiment-badge sentiment-{{ r.sentiment }}">{% if r.sentiment == 'positif' %}😊 Sentiment positif{% elseif r.sentiment == 'negatif' %}😞 Sentiment négatif{% else %}😐 Sentiment neutre{% endif %}</span></div>
                                </div>
                                {% endif %}
                                {% if r.reponse %}
                                <div class="mb-3">
                                    <label class="text-muted" style="font-size:12px;">Réponse de l'administration</label>
                                    <div class="reclamation-detail reclamation-response">
                                        <div style="margin-bottom:8px;"><strong>{{ r.reponsePar ? r.reponsePar.prenom ~ ' ' ~ r.reponsePar.nom : 'Administration' }}</strong> - {{ r.reponseDate|date('d/m/Y H:i') }}</div>
                                        {{ r.reponse|nl2br }}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            <div style="padding:0 25px 25px;display:flex;gap:12px;justify-content:flex-end;">
                                <button type="button" class="btn-admin outline" data-dismiss="modal">Fermer</button>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

<!-- Modal Modification -->
<div class="modal fade modal-admin" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:600px;">
        <div class="modal-content" style="border:none;border-radius:16px;overflow:hidden;">
            <div style="background:linear-gradient(135deg,var(--primary),#4C49ED);padding:20px 25px;">
                <h5 style="color:#fff;font-weight:700;margin:0;"><i class="fas fa-pen mr-2"></i>Modifier la réclamation</h5>
            </div>
            <form id="editForm" method="post" enctype="multipart/form-data" novalidate data-inline-validate>
                <div style="padding:25px;">
                    <div class="mb-3">
                        <label style="font-size:13px;font-weight:600;color:var(--primary-dark);display:block;margin-bottom:6px;">Type <span style="color:#dc2626;">*</span></label>
                        <select name="type" id="edit_type" class="form-control" style="border-radius:10px;border:1px solid var(--border);padding:10px 15px;" required>
                            <option value="technique">💻 Problème technique</option>
                            <option value="compte">👤 Problème de compte</option>
                            <option value="transaction">💰 Transaction</option>
                            <option value="carte">💳 Carte bancaire</option>
