{% block javascripts %}
<script>
function openEditModal(id, sujet, description, type) {
    document.getElementById('editForm').action = '/client/reclamations/' + id + '/edit';
    document.getElementById('edit_sujet').value = sujet;
    document.getElementById('edit_description').value = description;
    document.getElementById('edit_type').value = type;
    $('#editModal').modal('show');
}


function getInlineValidationMessage(field) {
    const value = field.value.trim();

    // Champ obligatoire
    if (field.validity.valueMissing) {
        return 'Ce champ est obligatoire.';
    }

    // Sujet (anti spam + qualité)
    if (field.name === 'sujet') {
        if (value.length < 5) return 'Le sujet doit contenir au moins 5 caractères.';
        if (value.length > 100) return 'Le sujet est trop long.';
        if (!/^[a-zA-Z0-9À-ÿ\s\-\'?!.,]+$/.test(value)) {
            return 'Caractères invalides dans le sujet.';
        }
    }

    // Description (important en bancaire)
    if (field.name === 'description') {
        if (value.length < 10) return 'Description trop courte.';
        if (value.length > 1000) return 'Description trop longue.';
    }

    // Type
    if (field.name === 'type' && !value) {
        return 'Veuillez sélectionner un type.';
    }

    // Image
    if (field.type === 'file' && field.files.length > 0) {
        const file = field.files[0];

        const allowedTypes = ['image/jpeg', 'image/png', 'image/gif'];
        if (!allowedTypes.includes(file.type)) {
            return 'Format invalide (JPG, PNG, GIF uniquement).';
        }

        if (file.size > 5 * 1024 * 1024) {
            return 'Image trop volumineuse (max 5MB).';
        }
    }

    return '';
}

function validateInlineField(field, form) {
    var targetName = field.name;
    var errorEl = form.querySelector('[data-error-for="' + targetName + '"]');

    if (!errorEl) return true;

    var message = getInlineValidationMessage(field);
    var isValid = message === '';

    field.classList.toggle('input-error', !isValid);
    field.classList.toggle('input-success', isValid && field.value.trim() !== '');

    errorEl.textContent = message;
    errorEl.classList.toggle('is-visible', !isValid);

    return isValid;
}

function setupInlineValidation(form) {
    if (!form) return;

    var fields = form.querySelectorAll('input[name], textarea[name], select[name]');

    fields.forEach(function(field) {
        field.addEventListener('input', function() {
            validateInlineField(field, form);
        });
        field.addEventListener('change', function() {
            validateInlineField(field, form);
        });
    });

    form.addEventListener('submit', function(event) {
        var firstInvalid = null;
        var valid = true;

        fields.forEach(function(field) {
            if (!validateInlineField(field, form)) {
                valid = false;
                if (!firstInvalid) {
                    firstInvalid = field;
                }
            }
        });

        if (!valid) {
            event.preventDefault();
            if (firstInvalid) {
                firstInvalid.focus();
            }
        }
    });
}

document.querySelectorAll('form[data-inline-validate]').forEach(setupInlineValidation);
</script>
{% endblock %}