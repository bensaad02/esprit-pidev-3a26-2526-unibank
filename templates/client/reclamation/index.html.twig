{# templates/client/reclamation/index.html.twig #}
{% extends 'client/base.html.twig' %}
{% block title %}Mes Réclamations - UniBank+{% endblock %}
{% block page_title %}Mes Réclamations{% endblock %}

{% block stylesheets %}
<style>
.field-error {
    display: none;
    color: #dc2626;
    font-size: 12px;
    margin-top: 6px;
    font-weight: 600;
}

.field-error.is-visible {
    display: block;
}

.form-control.input-error,
textarea.input-error,
select.input-error {
    border-color: #dc2626 !important;
    box-shadow: 0 0 0 0.12rem rgba(220, 38, 38, 0.12);
}

.form-control.input-success,
textarea.input-success,
select.input-success {
    border-color: #4CAF50 !important;
    box-shadow: 0 0 0 0.12rem rgba(76, 175, 80, 0.15);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 15px;
    margin-bottom: 25px;
}

.stat-card-mini {
    background: white;
    border-radius: 12px;
    padding: 15px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: transform 0.2s;
}

.stat-card-mini:hover {
    transform: translateY(-2px);
}

.stat-icon-mini {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
}

.stat-icon-mini.orange { background: #FFF3E0; color: #FF9800; }
.stat-icon-mini.blue { background: #E3F2FD; color: #2196F3; }
.stat-icon-mini.green { background: #E8F5E9; color: #4CAF50; }
.stat-icon-mini.red { background: #FFEBEE; color: #F44336; }

.stat-info-mini {
    flex: 1;
}

.stat-label-mini {
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 3px;
}

.stat-value-mini {
    font-size: 20px;
    font-weight: 700;
    color: var(--primary-dark);
}

.badge-status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
}

.badge-status.en_attente { background: #FFF3E0; color: #FF9800; }
.badge-status.en_cours { background: #E3F2FD; color: #2196F3; }
.badge-status.traite { background: #E8F5E9; color: #4CAF50; }
.badge-status.rejete { background: #FFEBEE; color: #F44336; }

.sentiment-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
}

.sentiment-positif { background: #E8F5E9; color: #4CAF50; }
.sentiment-negatif { background: #FFEBEE; color: #F44336; }
.sentiment-neutre { background: #F5F5F5; color: #757575; }

.response-preview {
    max-width: 200px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 13px;
    color: var(--text-secondary);
}

.has-response {
    color: #4CAF50;
}

.no-response {
    color: #FF9800;
}

.image-preview {
    max-width: 50px;
    max-height: 50px;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s;
}

.image-preview:hover {
    transform: scale(1.05);
}

.reclamation-detail {
    background: var(--bg);
    border-radius: 10px;
    padding: 15px;
    margin-top: 15px;
}

.reclamation-response {
    background: #E8F5E9;
    border-left: 4px solid #4CAF50;
}

.btn-action {
    background: transparent;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--text-secondary);
}

.btn-action:hover {
    background: #f0f0f0;
}

.btn-action.edit:hover { color: #FF9800; background: #FFF3E0; }
.btn-action.delete:hover { color: #F44336; background: #FFEBEE; }
.btn-action.view:hover { color: #2196F3; background: #E3F2FD; }

/* Barre de recherche pro */
.search-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

/* Input group */
.search-input-group {
    position: relative;
    flex: 1;
    max-width: 350px;
}

/* Icône */
.search-icon {
    position: absolute;
    top: 50%;
    left: 12px;
    transform: translateY(-50%);
    color: #9CA3AF;
    font-size: 14px;
}

/* Input */
.search-input {
    width: 100%;
    padding: 10px 15px 10px 38px;
    border-radius: 10px;
    border: 1px solid #E5E7EB;
    font-size: 14px;
    transition: all 0.2s ease;
    background: #F9FAFB;
}

/* Focus effet premium */
.search-input:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(76, 73, 237, 0.08);
}

/* Bouton principal */
.btn-search {
    background: linear-gradient(135deg, var(--primary), #4C49ED);
    color: #fff;
    border: none;
    padding: 10px 18px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
}

/* Hover bouton */
.btn-search:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(76, 73, 237, 0.2);
}

/* Reset */
.btn-reset {
    background: #F3F4F6;
    color: #374151;
    padding: 10px 15px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
}

.btn-reset:hover {
    background: #E5E7EB;
}

.search-select {
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #E5E7EB;
    background: #F9FAFB;
    font-size: 13px;
    cursor: pointer;
    transition: 0.2s;
}

.search-select:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(76, 73, 237, 0.08);
}

/* ============================================
   STYLES POUR NOTIFICATIONS ANIMÉES
============================================ */

/* Conteneur des notifications */
#response-notifications {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 12px;
    pointer-events: none;
}

/* Style de base de la notification */
.notification-toast {
    pointer-events: auto;
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.25), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    min-width: 320px;
    max-width: 400px;
    opacity: 0;
    transform: translateX(100px) scale(0.9);
    animation: notificationSlideIn 0.5s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
    position: relative;
}

/* Animation d'entrée */
@keyframes notificationSlideIn {
    0% {
        opacity: 0;
        transform: translateX(100px) scale(0.8);
    }
    60% {
        opacity: 1;
        transform: translateX(-10px) scale(1.02);
    }
    100% {
        opacity: 1;
        transform: translateX(0) scale(1);
    }
}

/* Animation de sortie */
.notification-toast.hide {
    animation: notificationSlideOut 0.4s ease-in forwards;
}

@keyframes notificationSlideOut {
    0% {
        opacity: 1;
        transform: translateX(0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translateX(100px) scale(0.8);
        display: none;
    }
}

/* Barre de progression */
.notification-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, #4CAF50, #66BB6A);
    width: 100%;
    animation: progressBar 5s linear forwards;
}

@keyframes progressBar {
    0% { width: 100%; }
    100% { width: 0%; }
}

/* En-tête de notification */
.notification-header {
    padding: 14px 16px 8px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
}

.notification-icon {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    animation: iconPulse 0.6s ease-out;
}

@keyframes iconPulse {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
}

.notification-title {
    flex: 1;
}

.notification-title h4 {
    color: white;
    margin: 0;
    font-size: 15px;
    font-weight: 700;
}

.notification-title p {
    color: rgba(255,255,255,0.9);
    margin: 2px 0 0;
    font-size: 11px;
}

.notification-close {
    background: rgba(255,255,255,0.2);
    border: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    color: white;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.notification-close:hover {
    background: rgba(255,255,255,0.4);
    transform: rotate(90deg);
}

/* Corps de notification */
.notification-body {
    padding: 16px;
    background: white;
}

.notification-subject {
    font-weight: 700;
    color: #1a202c;
    font-size: 14px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
}

.notification-message {
    color: #4a5568;
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 10px;
}

.notification-time {
    font-size: 11px;
    color: #a0aec0;
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Animation de bounce pour nouvelle notification */
@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
}

.notification-toast.new {
    animation: notificationSlideIn 0.5s cubic-bezier(0.34, 1.2, 0.64, 1) forwards, bounce 0.5s ease 0.3s;
}

/* Confettis animation */
@keyframes confettiFall {
    0% {
        transform: translateY(-100vh) rotate(0deg);
        opacity: 1;
    }
    100% {
        transform: translateY(100vh) rotate(360deg);
        opacity: 0;
    }
}

.confetti {
    position: fixed;
    pointer-events: none;
    z-index: 10000;
}

/* Sonnerie */
@keyframes ring {
    0% { transform: rotate(0deg); }
    25% { transform: rotate(15deg); }
    50% { transform: rotate(-15deg); }
    75% { transform: rotate(5deg); }
    100% { transform: rotate(0deg); }
}

.bell-ring {
    animation: ring 0.5s ease-in-out;
}

/* Badge compteur de notifications */
.notification-badge {
    position: relative;
}

.notification-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #F44336;
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 20px;
    min-width: 18px;
    text-align: center;
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

/* ============================================
   STYLES POUR LA PAGINATION
============================================ */
.pagination-container {
    margin-top: 25px;
    animation: fadeIn 0.3s ease;
}

.pagination {
    gap: 6px;
    flex-wrap: wrap;
}

.page-link {
    border-radius: 10px !important;
    border: none;
    padding: 8px 14px;
    color: var(--primary-dark);
    background: white;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    transition: all 0.2s ease;
    font-weight: 500;
}

.page-link:hover {
    background: linear-gradient(135deg, var(--primary), #4C49ED);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(76, 73, 237, 0.25);
}

.page-item.active .page-link {
    background: linear-gradient(135deg, var(--primary), #4C49ED);
    color: white;
    box-shadow: 0 4px 12px rgba(76, 73, 237, 0.3);
}

.page-item.disabled .page-link {
    background: #f5f5f5;
    color: #aaa;
    cursor: not-allowed;
    transform: none;
}

.pagination-info {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 15px;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
{% endblock %}

{% block body %}
<!-- Formulaire de nouvelle réclamation -->
<div class="admin-card mb-4">

    <div id="response-notifications"></div>

    <!-- Script de notification avec animations -->
    <script>
    // Queue des notifications pour éviter les surcharges
    let notificationQueue = [];
    let isShowingNotification = false;
    
    // Fonction pour afficher une notification avec animation
    function showNotification(notificationData) {
        notificationQueue.push(notificationData);
        processNotificationQueue();
    }
    
    function processNotificationQueue() {
        if (isShowingNotification || notificationQueue.length === 0) return;
        
        isShowingNotification = true;
        const data = notificationQueue.shift();
        
        const container = document.getElementById('response-notifications');
        if (!container) {
            isShowingNotification = false;
            return;
        }
        
        // Créer l'élément de notification
        const toast = document.createElement('div');
        toast.className = 'notification-toast new';
        
        toast.innerHTML = `
            <div class="notification-header">
                <div class="notification-icon">
                    ${data.icon || '📬'}
                </div>
                <div class="notification-title">
                    <h4>${data.title}</h4>
                    <p>${data.subtitle || 'Nouvelle réponse'}</p>
                </div>
                <button class="notification-close" onclick="closeNotification(this.parentElement.parentElement)">×</button>
            </div>
            <div class="notification-body">
                <div class="notification-subject">
                    <span>📌</span>
                    <span>${escapeHtml(data.subject)}</span>
                </div>
                <div class="notification-message">
                    ${escapeHtml(data.message)}
                </div>
                <div class="notification-time">
                    <span>🕐</span>
                    <span>${data.time}</span>
                </div>
            </div>
            <div class="notification-progress"></div>
        `;
        
        container.appendChild(toast);
        
        // Animation de sonnerie (optionnelle)
        playNotificationSound();
        
        // Confettis pour les réponses importantes
        if (data.isImportant) {
            createConfetti();
        }
        
        // Auto-suppression après 5 secondes
        const timeout = setTimeout(() => {
            closeNotification(toast);
        }, 5000);
        
        // Stocker le timeout pour l'annuler si nécessaire
        toast.dataset.timeout = timeout;
    }
    
    function closeNotification(element) {
        const timeout = element.dataset.timeout;
        if (timeout) clearTimeout(parseInt(timeout));
        
        element.classList.add('hide');
        
        setTimeout(() => {
            if (element.parentElement) {
                element.remove();
            }
            isShowingNotification = false;
            processNotificationQueue();
        }, 400);
    }
    
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    function playNotificationSound() {
        try {
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            oscillator.frequency.value = 880;
            gainNode.gain.value = 0.15;
            
            oscillator.start();
            gainNode.gain.exponentialRampToValueAtTime(0.00001, audioContext.currentTime + 0.5);
            oscillator.stop(audioContext.currentTime + 0.5);
            
            audioContext.resume();
        } catch(e) {
            // Fallback silencieux
        }
    }
    
    function createConfetti() {
        const colors = ['#4CAF50', '#2196F3', '#FF9800', '#F44336', '#9C27B0'];
        
        for (let i = 0; i < 30; i++) {
            const confetti = document.createElement('div');
            confetti.className = 'confetti';
            confetti.style.position = 'fixed';
            confetti.style.left = Math.random() * 100 + '%';
            confetti.style.top = '-20px';
            confetti.style.width = Math.random() * 8 + 4 + 'px';
            confetti.style.height = Math.random() * 8 + 4 + 'px';
            confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
            confetti.style.opacity = Math.random() * 0.7 + 0.3;
            confetti.style.animation = `confettiFall ${Math.random() * 2 + 2}s linear forwards`;
            
            document.body.appendChild(confetti);
            
            setTimeout(() => confetti.remove(), 3000);
        }
    }
    
    // Compteur de notifications
    let notificationCount = 0;
    
    function updateNotificationBadge(count) {
        notificationCount += count;
        
        let badge = document.querySelector('.notification-badge .notification-count');
        if (!badge && notificationCount > 0) {
            const title = document.querySelector('title');
            const badgeContainer = document.createElement('div');
            badgeContainer.className = 'notification-badge';
            badgeContainer.style.position = 'fixed';
            badgeContainer.style.top = '10px';
            badgeContainer.style.right = '10px';
            badgeContainer.style.zIndex = '10000';
            
            badge = document.createElement('div');
            badge.className = 'notification-count';
            badgeContainer.appendChild(badge);
            document.body.appendChild(badgeContainer);
        }
        
        if (badge) {
            if (notificationCount > 0) {
                badge.textContent = notificationCount > 99 ? '99+' : notificationCount;
                badge.style.display = 'block';
            } else {
                badge.style.display = 'none';
            }
        }
        
        // Mettre à jour le titre de la page
        if (notificationCount > 0) {
            document.title = `(${notificationCount}) ${document.title.replace(/^\(\d+\)\s/, '')}`;
        } else {
            document.title = document.title.replace(/^\(\d+\)\s/, '');
        }
    }
    
    // Stockage des notifications déjà affichées
    let displayedNotifications = new Set();
    </script>
    
    <script>
    document.addEventListener("DOMContentLoaded", function() {
        let notifications = [];

        {% for r in pagination %}
            {% if r.reponses|length > 0 %}
                {% set rep = r.reponses|sort((a, b) => a.dateReponse <=> b.dateReponse)|last %}
                notifications.push({
                    id: "{{ rep.id }}",
                    subject: "{{ r.sujet|e('js') }}",
                    message: "{{ rep.contenu|slice(0,150)|e('js') }}",
                    time: "{{ rep.dateReponse|date('d/m/Y H:i') }}",
                    timestamp: {{ rep.dateReponse.timestamp }}
                });
            {% endif %}
        {% endfor %}

        notifications.sort((a, b) => b.timestamp - a.timestamp);

        let seen = JSON.parse(localStorage.getItem("seen_notifications") || "[]");

        notifications.forEach((n, index) => {
            if (seen.includes(n.id)) return;
            updateNotificationBadge(1);
            setTimeout(() => {
                showNotification({
                    title: "📬 Nouvelle réponse",
                    subtitle: "Réponse non lue",
                    subject: n.subject,
                    message: n.message,
                    time: n.time,
                    icon: "💬",
                    isImportant: true
                });
                seen.push(n.id);
                localStorage.setItem("seen_notifications", JSON.stringify(seen));
                setTimeout(() => updateNotificationBadge(-1), 6000);
            }, index * 400);
        });
    });
    </script>

   <div class="card-header">
    <h5><i class="fas fa-comment-alt mr-2" style="color:var(--primary);"></i>Nouvelle réclamation</h5>
</div>
