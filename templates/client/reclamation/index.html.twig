            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    
    <form method="post" action="{{ path('app_client_reclamation_new') }}" enctype="multipart/form-data" id="reclamationForm" novalidate>
