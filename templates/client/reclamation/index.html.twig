                <input type="text" name="sujet" class="form-control" style="border-radius:10px;border:1px solid var(--border);padding:10px 15px;" 
                       value="{{ form_data.sujet|default('') }}" 
                       placeholder="Ex: Problème de virement">
                <div class="field-error" data-error-for="sujet"></div>
            </div>
        </div>
        
        <div class="mb-3">
            <label style="font-size:13px;font-weight:600;color:var(--primary-dark);display:block;margin-bottom:6px;">
