{# templates/client/reclamation/show.html.twig #}

<h2>Détails de la réclamation</h2>
<p><strong>Sujet:</strong> {{ reclamation.sujet }}</p>
<p><strong>Description:</strong> {{ reclamation.description }}</p>

<h3>Réponses</h3>
{% if reclamation.reponses|length > 0 %}
    <ul>
    {% for rep in reclamation.reponses %}
        <li>
            <strong>Auteur:</strong> {{ rep.auteur.nom }}<br>
            <strong>Message:</strong> {{ rep.message }}<br>
            <small>{{ rep.dateReponse|date('d/m/Y H:i') }}</small>
        </li>
    {% endfor %}
    </ul>
{% else %}
    <p>Aucune réponse pour le moment.</p>
{% endif %}